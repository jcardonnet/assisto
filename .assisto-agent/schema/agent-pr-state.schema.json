{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assisto.local/schema/agent-pr-state.schema.json",
  "title": "AgentPrState",
  "type": "object",
  "required": ["pr", "state", "transitions", "review_threads_path"],
  "properties": {
    "pr": { "type": "string" },
    "state": {
      "enum": [
        "branch_created",
        "implementation_done",
        "validation_passed",
        "memory_guard_passed",
        "pr_opened",
        "review_requested",
        "wait_elapsed",
        "review_threads_checked",
        "fixes_applied",
        "ci_green",
        "merge_ready",
        "merged",
        "main_synced",
        "mixedbread_refreshed",
        "closed_out"
      ]
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["state", "pr", "changed_at"],
        "properties": {
          "state": { "type": "string" },
          "pr": { "type": "string" },
          "changed_at": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "review_threads_path": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
