{
  "name": "Assisto",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "remoteEnv": {
    "COREPACK_HOME": "/tmp/corepack",
    "LOCALAPPDATA": "/tmp",
    "XDG_CACHE_HOME": "/tmp",
    "PLAYWRIGHT_BROWSERS_PATH": "/ms-playwright",
    "TMPDIR": "/tmp",
    "TEMP": "/tmp",
    "TMP": "/tmp"
  },
  "containerEnv": {
    "GH_TOKEN": "${localEnv:GH_TOKEN}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}",
    "MXBAI_API_KEY": "${localEnv:MXBAI_API_KEY}",
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "ASSISTO_OPENAI_MODEL": "${localEnv:ASSISTO_OPENAI_MODEL}",
    "ASSISTO_OPENAI_BASE_URL": "${localEnv:ASSISTO_OPENAI_BASE_URL}"
  },
  "postCreateCommand": "corepack enable && corepack prepare pnpm@9.15.4 --activate && pnpm install && pnpm exec playwright install --with-deps chromium",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
