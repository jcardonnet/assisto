{
  "name": "work-memory-assistant",
  "version": "0.0.0",
  "private": true,
  "description": "Local-first markdown work-memory assistant MVP scaffold.",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "node tests/run-unit.mjs",
    "test:integration": "node tests/run-integration.mjs",
    "test": "node tests/run-tests.mjs",
    "test:e2e": "node tests/run-e2e.mjs",
    "test:browser": "playwright test --project=chromium",
    "eval:mvp": "node tests/scenarios/run-mvp.mjs",
    "eval:v2": "node tests/scenarios/run-v2.mjs",
    "eval:v3": "node tests/scenarios/run-v3.mjs",
    "eval:retrieval": "node tests/scenarios/run-retrieval.mjs",
    "eval:v4": "node tests/scenarios/run-v4.mjs",
    "eval:v5": "node tests/scenarios/run-v5.mjs",
    "eval:v6": "node tests/scenarios/run-v6.mjs",
    "eval:v7": "node tests/scenarios/run-v7.mjs",
    "eval:dogfood-local": "node tests/scenarios/run-dogfood-local.mjs",
    "validate:local": "node scripts/validate-local.mjs",
    "validate:ci-parity": "node scripts/validate-local.mjs --ci-parity",
    "env:doctor": "node scripts/env-doctor.mjs",
    "check:memory-data": "node scripts/check-memory-data.mjs",
    "pr:review-wait": "node scripts/wait-for-pr-review.mjs",
    "pr:closeout": "node scripts/agent-pr.mjs closeout",
    "mxbai:upload": "bash scripts/mxbai-upload.sh",
    "mxbai:smoke": "bash scripts/mxbai-smoke.sh",
    "agent:start": "node scripts/agent-control.mjs start",
    "agent:status": "node scripts/agent-control.mjs status",
    "agent:handoff": "node scripts/agent-control.mjs handoff",
    "agent:note": "node scripts/agent-control.mjs note",
    "agent:policy": "node scripts/agent-policy.mjs policy",
    "agent:validate": "node scripts/agent-policy.mjs validate",
    "agent:run": "node scripts/agent-run.mjs run",
    "agent:diagnose:last": "node scripts/agent-run.mjs diagnose-last",
    "agent:diagnose": "node scripts/agent-run.mjs diagnose",
    "agent:pr": "node scripts/agent-pr.mjs",
    "agent:ci-local": "node scripts/agent-ci-local.mjs",
    "agent:map": "node scripts/agent-map.mjs",
    "agent:workbench": "node scripts/agent-workbench.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
